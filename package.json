{
  "name": "agentlens",
  "version": "0.1.0",
  "description": "Chrome DevTools for AI agents — record, replay, inspect, and test agent sessions from your terminal",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "alens": "dist/cli.js",
    "agentlens": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "clean": "rm -rf dist/",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "ai",
    "agents",
    "devtools",
    "debugging",
    "testing",
    "llm",
    "claude",
    "openai",
    "observability",
    "tracing"
  ],
  "author": "RyanHub <hello@ryanwang.dev>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/zzhiyuann/agentlens"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "better-sqlite3": "^11.0.0",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "ink": "^5.1.0",
    "ink-text-input": "^6.0.0",
    "js-yaml": "^4.1.0",
    "nanoid": "^5.0.9",
    "react": "^18.3.1",
    "cli-table3": "^0.6.5",
    "date-fns": "^4.1.0",
    "glob": "^11.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.12",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ]
}
